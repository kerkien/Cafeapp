<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:fitsSystemWindows="true"
        android:background="?attr/colorPrimary">

        <TextView
            android:id="@+id/txtTableNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Table: "
            android:layout_marginTop="8dp"
            android:paddingTop="8dp"
            android:layout_gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>
        <TextView
            android:id="@+id/txtCartSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Table: "
            android:layout_marginTop="8dp"
            android:paddingTop="8dp"
            android:layout_gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <!-- Search bar (optional) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:hint="Search coffee"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/search_background"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"/>
    </LinearLayout>

    <!-- Category tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/categoryTabsContainer"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <!-- Category buttons will be added dynamically -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- GridView for menu items -->
    <GridView
        android:id="@+id/gridViewMenu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:gravity="center_horizontal"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:padding="10dp"
        android:stretchMode="columnWidth"/>

    <!-- Place Order Button -->
    <Button
        android:id="@+id/btnPlaceOrder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place Order"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/category_selected_bg"
        android:layout_margin="16dp"
        android:padding="16dp"/>

</LinearLayout>