<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:backgroundTint="@color/accent"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtOrderTable"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Table: X"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtOrderItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="- Item 1\n- Item 2\n- Item 3"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/txtOrderTimestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="12:00 PM"
        android:gravity="end"
        android:textSize="12sp"
        android:layout_marginTop="8dp"/>

    <LinearLayout
        android:id="@+id/layoutBaristaActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnStartPreparing"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Start Preparing"
            android:visibility="gone"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFinishOrder"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Finish"
            android:visibility="gone"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</LinearLayout>